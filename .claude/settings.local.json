{
  "defaultMode": "bypassPermissions",
  "permissions": {
    "deny": [
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(docker run:*)",
      "WebFetch",
      "Read(.env*)"
    ],
    "allow": [
      "Bash(curl:*)",
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(grep:*)",
      "Bash(git diff:*)",
      "Bash(done)",
      "Bash(dir:*)",
      "Bash(wc:*)",
      "Skill(playwright-cli)",
      "Skill(playwright-cli:*)",
      "Bash(playwright-cli*)",
      
      "Bash(pnpm *)",
      "mcp__plugin_playwright_playwright__browser_take_screenshot"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase"
  ]
}
